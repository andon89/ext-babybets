{
  "expo": {
    "name": "Baby Bets",
    "slug": "babybets",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "babybets",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#FFF9F2"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.babybets.app",
      "usesAppleSignIn": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFF9F2"
      },
      "package": "com.babybets.app"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      "expo-apple-authentication"
    ]
  }
}
